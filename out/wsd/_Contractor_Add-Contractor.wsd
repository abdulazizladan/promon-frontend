@startuml [Contractor] Add Contractor

set namespaceSeparator ::
skinparam class {
    BackgroundColor<<listen>> HoneyDew
    BackgroundColor<<action>> Wheat
    BackgroundColor<<dispatch>> Technology
}

interface "[Contractor] Add Contractor" << (A,#FF7700) action >> {
            variable: addContractor
            src: contractor.actions
            --
            props<{contractor: Contractor}>

        }

         

@enduml