@startuml [Project] Update Project

set namespaceSeparator ::
skinparam class {
    BackgroundColor<<listen>> HoneyDew
    BackgroundColor<<action>> Wheat
    BackgroundColor<<dispatch>> Technology
}

interface "[Project] Update Project" << (A,#FF7700) action >> {
            variable: updateProject
            src: project.actions
            --
            props<{project: Project}>

        }

         

@enduml